# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/deity
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/deity?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production-minimum-32-characters-long

# JWT Secret (generate a random string)
JWT_SECRET=your-jwt-secret-key-change-this-in-production-minimum-32-characters-long

# Stripe Configuration (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Public API URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Qikink API Configuration
QIKINK_BASE_URL=https://api.qikink.com
QIKINK_API_KEY=DUMMY_API_KEY
QIKINK_API_SECRET=DUMMY_API_SECRET

# Node Environment
NODE_ENV=development
